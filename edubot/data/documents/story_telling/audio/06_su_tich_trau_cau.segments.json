{
  "id": "06",
  "title": "Sự tích trầu cau",
  "source_text_chars": 882,
  "output_wav": "D:\\STUDY\\At_school\\asr_zipformer\\edubot\\data\\documents\\story_telling\\audio\\06_s_t_ch_tr_u_cau.wav",
  "sample_rate": 22050,
  "duration_seconds": 52.579,
  "segments": [
    {
      "text": "Chuyện kể về 2 anh em Tân và Lang giống nhau như đúc,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.892,
      "paragraph_end": false
    },
    {
      "text": "luôn sống hòa thuận và yêu thương nhau.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Sau khi Tân lấy vợ, Lang vẫn tiếp tục sống cùng anh chị.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Thế nhưng, sau sự cố vợ Tân nhầm lẫn Lang là chồng nên đã khiến Tân ghen ghét em.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Thấy vậy, Lang buồn bã bỏ đi rồi chết bên bờ suối, hóa thành tảng đá vôi.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Không thấy em về, Tân liền đi tìm và gục ngã bên tảng đá hóa thành cây cau.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Sau đó,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.866,
      "paragraph_end": false
    },
    {
      "text": "người vợ cũng đi tìm chồng rồi mệt quá dựa vào thân cau mà chết rồi hóa thành cây",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "trầu.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.941,
      "paragraph_end": false
    },
    {
      "text": "Về sau, nhà vua có việc đi ngang qua đây, bèn lấy lá trầu ăn với cau và vôi.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Thấy vị thơm nồng,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.866,
      "paragraph_end": false
    },
    {
      "text": "màu sắc đỏ tươi,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.866,
      "paragraph_end": false
    },
    {
      "text": "nhà vua đã cho nhân giống cau trầu và thường sử dụng trầu cau trong những dịp lễ",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "quan trọng.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.941,
      "paragraph_end": false
    },
    {
      "text": "Sự tích trầu cau giải thích cho bé biết phong tục ăn trầu cau của người Việt.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Qua đó,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.866,
      "paragraph_end": false
    },
    {
      "text": "câu chuyện còn dạy cho bé bài học:",
      "punctuation": ":",
      "pause_ms": 200,
      "length_scale": 0.931,
      "paragraph_end": false
    },
    {
      "text": "anh em,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.866,
      "paragraph_end": false
    },
    {
      "text": "vợ chồng phải luôn yêu thương,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.892,
      "paragraph_end": false
    },
    {
      "text": "trân trọng và chung thuỷ với nhau.",
      "punctuation": ".",
      "pause_ms": 440,
      "length_scale": 0.97,
      "paragraph_end": true
    }
  ]
}