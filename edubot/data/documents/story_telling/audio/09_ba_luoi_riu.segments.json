{
  "id": "09",
  "title": "Ba lưỡi rìu",
  "source_text_chars": 579,
  "output_wav": "D:\\STUDY\\At_school\\asr_zipformer\\edubot\\data\\documents\\story_telling\\audio\\09_ba_l_i_r_u.wav",
  "sample_rate": 22050,
  "duration_seconds": 33.955,
  "segments": [
    {
      "text": "Ba lưỡi rìu là câu chuyện kể về một anh tiều phu nghèo với gia sản chỉ có một lưỡi",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "rìu.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.941,
      "paragraph_end": false
    },
    {
      "text": "Một hôm,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.866,
      "paragraph_end": false
    },
    {
      "text": "trong lúc đốn củi,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.866,
      "paragraph_end": false
    },
    {
      "text": "lưỡi rìu của anh bị gãy và rơi xuống dòng sông chảy xiết.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Anh buồn rầu, bật khóc nên Bụt hiện lên và hứa sẽ giúp anh tìm lại chiếc rìu.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Sau 2 lần vớt được rìu vàng và rìu bạc, anh đều thật thà bảo không phải của mình.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Lần thứ 3, khi Bụt đưa chiếc rìu sắt lên, anh mới sung sướng reo lên.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Nhờ tính trung thực, anh tiều phu được Bụt tặng cả rìu vàng và rìu bạc.",
      "punctuation": ".",
      "pause_ms": 260,
      "length_scale": 0.97,
      "paragraph_end": false
    },
    {
      "text": "Câu chuyện giúp trẻ hiểu rằng chỉ cần sống ngay thẳng,",
      "punctuation": ",",
      "pause_ms": 120,
      "length_scale": 0.892,
      "paragraph_end": false
    },
    {
      "text": "không tham lam thì sẽ được mọi người yêu quý.",
      "punctuation": ".",
      "pause_ms": 440,
      "length_scale": 0.97,
      "paragraph_end": true
    }
  ]
}